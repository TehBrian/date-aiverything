# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Vercel + Neon integration variables.
# In most setups you should not edit these manually; run:
#   vercel env pull .env.development.local
# POSTGRES_PRISMA_URL is the pooled connection Prisma Client should use.
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST/db?sslmode=require&pgbouncer=true&connect_timeout=15"
# POSTGRES_URL_NON_POOLING is used by Prisma Migrate for schema changes.
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST/db?sslmode=require"

# Optional for real LLM generation. If omitted, the app uses a deterministic fallback puzzle.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"

# Upload size ceiling in MB for local upload endpoint.
MAX_UPLOAD_MB="6"
